{
	"services": {
		"synflow-galaxy": {
			"label": "Synflow via Galaxy",
			"service": "galaxy",
			"command": "python3 /opt/home/summo/scripts/synflow.py --url https://usegalaxy.fr --delete-history --debug",
			"arguments": {
				"inputs": [
					{
						"name": "query",
						"label": "Query file",
						"type": "file",
						"flag": "--query",
						"default": "/opt/projects/VisuSNP/htdocs/toolkit/public/scripts/qrygenome.fasta",
						"required": true
					},
					{
						"name": "target",
						"label": "Target file (reference genome)",
						"type": "file",
						"flag": "--target",
						"default": "/opt/projects/VisuSNP/htdocs/toolkit/public/scripts/refgenome.fasta",
						"required": true
					},
					{
						"name": "workflow",
						"label": "Workflow",
						"type": "select",
						"flag": "--workflow",
						"optionsSource": "SyriWorkflows",
						"required": true
					}
				]
			}
		},
		"synflow": {
			"label": "Synflow",
			"service": "opal",
			"command": "python2 /opt/OpalPythonClient/opal-py-2.4.1/GenericServiceClient.py",
			"url": "http://io-biomaj.meso.umontpellier.fr:8080/opal2/services/synflow",
			"action": "launchJob",
			"arguments": {
				"inputs": [
					{
						"name": "inputs",
						"label": "FASTA files",
						"tooltip": "Genomes assemblies, minimum 2 genomes required",
						"type": "file[]",
						"flag": "-i",
						"default": [
							"/NAS/muse/web/HUBs/coffea/opal/C21.fasta",
							"/NAS/muse/web/HUBs/coffea/opal/DH.fasta"
						],
						"required": true
					},
					{
						"name": "gff",
						"label": "GFF3 files",
						"tooltip": "Gene annotation, required only for MCScanX",
						"type": "file[]",
						"flag": "-g",
						"required": false
					},
					{
						"name": "workflow",
						"label": "Method",
						"type": "select",
						"flag": "-m",
						"optionsSource": "SyriWorkflows",
						"required": true
					},
					{
						"name": "email",
						"label": "Email",
						"tooltip": "Email address to receive notification when the job is finished",
						"type": "text",
						"required": false
					}
				]
			}
		},
		"blast": {
			"label": "BLAST",
			"service": "opal",
			"command": "python2 /opt/OpalPythonClient/opal-py-2.4.1/GenericServiceClient.py",
			"url": "http://io-biomaj.meso.umontpellier.fr:8080/opal2/services/ncbi-blastn",
			"action": "launchJob",
			"arguments": {
				"inputs": [
					{
						"name": "db",
						"label": "Database",
						"type": "select",
						"flag": "-db",
						"optionsSource": "blastDBs",
						"required": true
					},
					{
						"name": "query",
						"label": "Query file",
						"type": "file",
						"flag": "-query",
						"default": "Macma4_04_g00010.fna",
						"required": true
					},
					{
						"name": "task",
						"label": "Task",
						"type": "text",
						"flag": "-task",
						"default": "blastn",
						"required": true
					},
					{
						"name": "output",
						"label": "Output file name",
						"type": "text",
						"flag": "-out",
						"default": "Macma4_04_g00010.out",
						"required": true
					}
				]
			}
		}
	},
	"databases": {
		"blastDBs": [
			"banana/Genomes/Musa_acuminata_ssp_malaccensis_4.3/Musa_acuminata_pahang_v4_gene.fna",
			"banana/Genomes/OtherDB/ExampleDB.fna",
			"banana/Genomes/ExampleDB2/AnotherDB.fna"
		],
		"SyriWorkflows": {
			"nucmer": {
				"advanced": [
				{
					"name": "min_length_cluster",
					"label": "Minimum cluster length",
					"tooltip": "Minimum length of a cluster of matches to be considered as a synteny block",
					"type": "text",
					"flag": "--min_length_cluster",
					"default": "500",
					"required": false
				},
				{
					"name": "min_distance_extension",
					"label": "Minimum distance extension",
					"tooltip": "Minimum distance to extend a cluster of matches to be considered as a synteny block",
					"type": "text",
					"flag": "--min_distance_extension",
					"default": "500",
					"required": false
				},
				{
					"name": "min_length_match",
					"label": "Minimum match length",
					"tooltip": "Minimum length of a match to be considered in the analysis",
					"type": "text",
					"flag": "--min_length_match",
					"default": "100",
					"required": false
				},
				{
					"name": "min_alignment_identity",
					"label": "Minimum alignment identity",
					"tooltip": "Minimum percentage of identity for an alignment to be considered in the analysis",
					"type": "text",
					"flag": "--min_alignment_identity",
					"default": "90",
					"required": false
				},
				{
					"name": "min_alignment_length",
					"label": "Minimum alignment length",
					"tooltip": "Minimum length of an alignment to be considered in the analysis",
					"type": "text",
					"flag": "--min_alignment_length",
					"default": "5000",
					"required": false
				}
				]
			},
			"minimap2": {
				"advanced":[
					{
						"name": "preset",
						"label": "Preset",
						"tooltip": "Preset for minimap2, choose asm5 for closely related genomes, asm10 for more distantly related genomes and asm6 for very closely related genomes",
						"type": "select",
						"flag": "-p",
						"options": [
							{"label": "asm5", "value": "asm5"},
							{"label": "asm10", "value": "asm10"},
							{"label": "asm20", "value": "asm20"}
						],
						"default": "asm5",
						"required": false	
					},
					{
						"name": "secondary",
						"label": "Secondary alignments",
						"tooltip": "Include secondary alignments in the analysis",
						"type": "select",
						"flag": "-s",
						"options": [
							{"label": "yes", "value": "yes"},
							{"label": "no", "value": "no"}
						],
						"default": "no",
						"required": false	
					},
					{
						"name": "bandwidth",
						"label": "Bandwidth for chaining and base alignment",
						"tooltip": "Bandwidth for chaining and base alignment (default 2k) for initial chaining and alignment extension",
						"type": "text",
						"flag": "--bandwidth",
						"default": "2000",
						"required": false	
					}
				]
			}
		},
			
		"anotherServiceDBs": [
			"path/to/db1.fna",
			"path/to/db2.fna"
		]
	}
}